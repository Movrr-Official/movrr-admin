# ============================================================
# MOVRR Admin - Environment Variables
# Copy this file to `.env` and replace placeholder values.
# ============================================================

# ------------------------------------------------------------
# Runtime
# ------------------------------------------------------------
NODE_ENV=development

# ------------------------------------------------------------
# App URLs (required)
# ------------------------------------------------------------
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional explicit customer app URL for rider-facing auth flows.
# If omitted, admin.movrr.nl automatically maps to app.movrr.nl.
NEXT_PUBLIC_CUSTOMER_APP_URL=http://localhost:8081

# ------------------------------------------------------------
# Supabase (required)
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ------------------------------------------------------------
# Database (required)
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# ------------------------------------------------------------
# Email / Notifications (required unless explicitly optional)
# ------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@movrr.nl
WELCOME_EMAIL=welcome@movrr.nl
ADMIN_EMAIL=admin@movrr.nl
# Optional comma-separated override for multiple admin recipients.
# Example: ADMIN_EMAILS=admin@movrr.nl,ops@movrr.nl
ADMIN_EMAILS=
SYSTEM_EMAIL=system@movrr.nl
SUPPORT_EMAIL=support@movrr.nl
# Optional
ERROR_WEBHOOK_URL=
# Optional bearer token for scheduled/privacy maintenance routes
MAINTENANCE_JOB_TOKEN=

# ------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------
NEXT_PUBLIC_USE_MOCK_DATA=false
USE_MOCK_DATA=false
NEXT_PUBLIC_USE_MOCK_RIDER_LOCATIONS=false

# ------------------------------------------------------------
# Maps
# When NEXT_PUBLIC_MAPTILER_API_KEY is set the map automatically uses
# MapTiler styles (streets-v2 / topo-v2 / hybrid satellite) which provide
# real terrain and aerial imagery.  Sign up free at https://maptiler.com.
# Without a key the map falls back to OpenFreeMap vector styles (no key
# required).  NEXT_PUBLIC_MAP_STYLE_* overrides are only used in fallback
# mode; they are ignored when the MapTiler key is present.
# ------------------------------------------------------------
NEXT_PUBLIC_MAPTILER_API_KEY=
# OpenFreeMap fallbacks (used only when no MapTiler key is set)
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty
NEXT_PUBLIC_MAP_STYLE_HOT_ZONES=https://tiles.openfreemap.org/styles/positron
NEXT_PUBLIC_MAP_STYLE_HYBRID=https://tiles.openfreemap.org/styles/bright

# ------------------------------------------------------------
# Route Optimizer
# ROUTE_OPTIMIZER_URL is required.
# Provide at least one of:
# - ROUTE_OPTIMIZER_TOKEN
# - ROUTE_OPTIMIZER_KEY
# ------------------------------------------------------------
ROUTE_OPTIMIZER_URL=https://route-optimizer.example.com
ROUTE_OPTIMIZER_TOKEN=
ROUTE_OPTIMIZER_KEY=
ROUTE_ALLOW_PREV_TOKEN=false
# Optional legacy/fallback tokens
ROUTE_OPTIMIZER_PREV_TOKEN=
ROUTE_OPTIMIZER_OLD_TOKEN=

# ------------------------------------------------------------
# Media Uploads (optional)
# ------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Advertiser logo uploads
NEXT_PUBLIC_SUPABASE_ADVERTISER_LOGO_BUCKET=advertiser-assets
NEXT_PUBLIC_ADVERTISER_LOGO_MAX_FILE_SIZE_MB=2
